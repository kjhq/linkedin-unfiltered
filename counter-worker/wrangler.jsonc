{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "linkedin-unfiltered-api",
  "main": "src/index.js",
  "compatibility_date": "2026-07-17",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "routes": [
    { "pattern": "api.kjhq.dev/*", "zone_name": "kjhq.dev" },
    { "pattern": "api.kjhq.dev", "zone_name": "kjhq.dev" }
  ]
}
